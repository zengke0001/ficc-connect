/* app.wxss - Global Styles */

/* CSS Variables */
page {
  --primary: #2563EB;
  --primary-light: #60A5FA;
  --primary-dark: #1D4ED8;
  --accent: #F59E0B;
  --accent-light: #FBBF24;
  --success: #10B981;
  --success-light: #34D399;
  --danger: #EF4444;
  --warning: #F59E0B;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F8FAFC;
  --bg-tertiary: #F1F5F9;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-muted: #94A3B8;
  --border: #E2E8F0;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
}

/* Layout */
.container {
  min-height: 100vh;
  background: var(--bg-secondary);
}

.page-scroll {
  height: 100vh;
  background: var(--bg-secondary);
}

/* Cards */
.card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.card-body {
  padding: 32rpx;
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx 40rpx;
  transition: all 0.2s;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  color: #FFFFFF;
  box-shadow: 0 4px 14rpx rgba(37, 99, 235, 0.35);
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 2px 8rpx rgba(37, 99, 235, 0.2);
}

.btn-checkin {
  background: linear-gradient(135deg, #10B981, #34D399);
  color: #FFFFFF;
  font-size: 34rpx;
  padding: 30rpx 60rpx;
  border-radius: 60rpx;
  box-shadow: 0 6px 20rpx rgba(16, 185, 129, 0.4);
  letter-spacing: 4rpx;
}

.btn-checkin:active {
  transform: scale(0.96);
}

.btn-done {
  background: var(--bg-tertiary);
  color: var(--text-muted);
  font-size: 28rpx;
  border-radius: 60rpx;
}

.btn-secondary {
  background: var(--bg-tertiary);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-block {
  width: 100%;
}

/* Gradient backgrounds */
.gradient-blue {
  background: linear-gradient(135deg, #2563EB, #60A5FA);
}

.gradient-green {
  background: linear-gradient(135deg, #10B981, #34D399);
}

.gradient-orange {
  background: linear-gradient(135deg, #F59E0B, #FBBF24);
}

.gradient-purple {
  background: linear-gradient(135deg, #7C3AED, #A78BFA);
}

/* Avatars */
.avatar {
  border-radius: 50%;
  background: var(--bg-tertiary);
}

.avatar-sm { width: 64rpx; height: 64rpx; }
.avatar-md { width: 88rpx; height: 88rpx; }
.avatar-lg { width: 120rpx; height: 120rpx; }
.avatar-xl { width: 160rpx; height: 160rpx; }

/* Tags / Badges */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-blue { background: #EFF6FF; color: #2563EB; }
.tag-green { background: #ECFDF5; color: #10B981; }
.tag-orange { background: #FFFBEB; color: #F59E0B; }
.tag-red { background: #FEF2F2; color: #EF4444; }
.tag-purple { background: #F5F3FF; color: #7C3AED; }

/* Dividers */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* Section titles */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-muted);
}

.empty-state .icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-state .text { font-size: 28rpx; }

/* Streak badge */
.streak-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #F59E0B, #EF4444);
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}

/* Points badge */
.points-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #7C3AED, #A78BFA);
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}

/* Loading */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in { animation: fadeIn 0.3s ease; }

@keyframes pop {
  0% { transform: scale(0.8); opacity: 0; }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.pop-in { animation: pop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); }

/* Safe area */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
