/* pages/activity-gallery/activity-gallery.wxss */

.page-container {
  min-height: 100vh;
  background: var(--bg-secondary);
}

/* Activity header */
.activity-header {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}
.header-cover {
  width: 100%;
  height: 100%;
}
.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 40rpx 24rpx 24rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
}
.header-dates {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* Winners */
.winners-section { 
  background: linear-gradient(160deg, var(--primary-dark), var(--primary-light)); 
  padding: 40rpx 32rpx; 
}
.winners-header { text-align: center; margin-bottom: 32rpx; }
.winners-title { font-size: 36rpx; font-weight: 800; color: white; }
.winners-row { 
  display: flex; 
  justify-content: center; 
  flex-wrap: wrap;
  margin: -10rpx;
}
.winner-card { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 10rpx;
}
.winner-rank { font-size: 40rpx; margin-bottom: 8rpx; }
.winner-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.6); }
.winner-name { font-size: 24rpx; color: white; margin-top: 10rpx; text-align: center; font-weight: 600; }
.winner-pts { font-size: 22rpx; color: rgba(255,255,255,0.9); }
.winner-streak { font-size: 18rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }

/* Stats */
.stats-bar {
  display: flex; 
  justify-content: space-around;
  background: #FFFFFF;
  box-shadow: var(--shadow);
  padding: 28rpx 40rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}
.stat-chip { text-align: center; }
.s-val { display: block; font-size: 32rpx; font-weight: 700; color: var(--primary); }
.s-key { display: block; font-size: 22rpx; color: var(--text-secondary); margin-top: 6rpx; }

.section-title {
  font-size: 28rpx; 
  font-weight: 600; 
  color: var(--text-primary);
  padding: 32rpx 24rpx 16rpx;
}

/* Loading */
.loading-state {
  text-align: center;
  padding: 60rpx;
  color: var(--text-muted);
}

/* Photo grid */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx;
}
.photo-item {
  width: 33.33%;
  position: relative;
  padding-bottom: 33.33%;
}
.photo-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.photo-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(transparent 50%, rgba(0,0,0,0.7));
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 16rpx 10rpx 10rpx;
}
.photo-user {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}
.user-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}
.user-name {
  font-size: 18rpx;
  color: white;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120rpx;
}
.photo-like {
  display: flex;
  align-items: center;
}
.like-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}
.like-num {
  font-size: 18rpx;
  color: white;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-muted);
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; }
