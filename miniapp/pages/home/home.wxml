<!-- pages/home/home.wxml -->
<scroll-view class="page-scroll" scroll-y>

  <!-- Header -->
  <view class="home-header gradient-blue">
    <view class="header-top">
      <view class="header-greeting">
        <view class="greeting-text">
          <text>Hello, </text><text class="nickname">{{userInfo.nickname}}</text><text> 👋</text>
        </view>
        <view class="greeting-sub">Keep the streak alive today!</view>
      </view>
      <image class="avatar avatar-md" src="{{userInfo.avatar_url}}" mode="aspectFill"
             bindtap="goToProfile"/>
    </view>

    <!-- Streak Banner -->
    <view class="streak-banner" wx:if="{{totalStreak > 0}}">
      <text class="streak-fire">🔥</text>
      <text class="streak-text">{{totalStreak}} day streak! Keep going!</text>
    </view>
  </view>

  <!-- Today's Activities -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">My Activities</view>
      <view class="section-link" bindtap="goToArchived">Archived ›</view>
    </view>

    <!-- Loading skeleton -->
    <block wx:if="{{loading}}">
      <view wx:for="{{[1,2]}}" wx:key="*this" class="skeleton-card"></view>
    </block>

    <!-- Activity cards -->
    <block wx:elif="{{todayActivities.length > 0}}">
      <view wx:for="{{todayActivities}}" wx:key="activity_id" class="activity-row card fade-in"
            bindtap="goToActivityDetail" data-id="{{item.activity_id}}">
        <image class="act-cover" src="{{item.cover_image_url || '/images/default-cover.jpg'}}" mode="aspectFill"/>
        <view class="act-info">
          <view class="act-title">{{item.title}}</view>
          <view class="act-meta">
            <view class="streak-badge" wx:if="{{item.current_streak > 0}}">
              <text>{{item.streakFlame}} {{item.current_streak}}d</text>
            </view>
          </view>
        </view>
        <view class="act-checkin-btn" catchtap="goToCheckin"
              data-activity-id="{{item.activity_id}}"
              data-has-checkin="{{item.has_checkin}}">
          <view wx:if="{{item.has_checkin}}" class="checkin-done">
            <text class="done-icon">✓</text>
            <text class="done-text">Done</text>
          </view>
          <view wx:else class="checkin-todo">
            <text class="todo-text">Check-in</text>
          </view>
        </view>
      </view>
    </block>

    <!-- Empty state -->
    <view wx:else class="empty-card card">
      <view class="empty-state">
        <text class="icon">🎯</text>
        <text class="text">No activities yet</text>
        <button class="btn btn-primary discover-btn" bindtap="goToDiscover">
          Discover
        </button>
      </view>
    </view>
  </view>

  <!-- Quick Actions -->
  <view class="section">
    <view class="section-title">Quick Actions</view>
    <view class="quick-actions">
      <view class="quick-item" bindtap="goToDiscover">
        <view class="quick-icon gradient-blue">🔍</view>
        <view class="quick-label">Discover</view>
      </view>
      <view class="quick-item" bindtap="goToCreate">
        <view class="quick-icon gradient-green">➕</view>
        <view class="quick-label">Create</view>
      </view>
      <view class="quick-item" bindtap="goToGallery">
        <view class="quick-icon gradient-orange">📸</view>
        <view class="quick-label">Gallery</view>
      </view>
      <view class="quick-item" bindtap="goToArchived">
        <view class="quick-icon gradient-purple">📂</view>
        <view class="quick-label">Archived</view>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>

</scroll-view>
