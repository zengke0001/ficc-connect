/* pages/home/home.wxss */
.home-header {
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
}
.header-top { display: flex; align-items: flex-start; justify-content: space-between; }
.greeting-text { font-size: 34rpx; color: rgba(255,255,255,0.9); }
.nickname { font-size: 36rpx; font-weight: 700; color: white; }
.greeting-sub { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; }
.streak-banner {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 100rpx;
  padding: 14rpx 28rpx;
  margin-top: 28rpx;
  backdrop-filter: blur(4px);
}
.streak-fire { font-size: 32rpx; }
.streak-text { font-size: 26rpx; color: white; font-weight: 600; }

.section { padding: 40rpx 32rpx 0; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #1E293B; }
.section-link { font-size: 26rpx; color: #2563EB; }

/* Activity row card */
.activity-row {
  display: flex; align-items: center; gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.act-cover { width: 100rpx; height: 100rpx; border-radius: 16rpx; flex-shrink: 0; background: #F1F5F9; }
.act-info { flex: 1; min-width: 0; }
.act-title { font-size: 30rpx; font-weight: 600; color: #1E293B; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.act-meta { display: flex; align-items: center; gap: 12rpx; margin-top: 10rpx; }

.act-checkin-btn { flex-shrink: 0; }
.checkin-done {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  background: #ECFDF5; border-radius: 16rpx; padding: 14rpx 24rpx;
}
.done-icon { font-size: 28rpx; color: #10B981; font-weight: 700; }
.done-text { font-size: 20rpx; color: #10B981; }
.checkin-todo {
  background: linear-gradient(135deg, #10B981, #34D399);
  border-radius: 16rpx; padding: 18rpx 28rpx;
  box-shadow: 0 4rpx 14rpx rgba(16,185,129,0.4);
}
.todo-text { font-size: 28rpx; font-weight: 700; color: white; letter-spacing: 4rpx; }

/* Empty card */
.empty-card { margin-bottom: 20rpx; }
.discover-btn { margin-top: 24rpx; padding: 20rpx 48rpx; font-size: 26rpx; }

/* Skeleton */
.skeleton-card {
  height: 148rpx; border-radius: 24rpx;
  background: linear-gradient(90deg, #F1F5F9 25%, #E2E8F0 50%, #F1F5F9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 20rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Quick actions */
.quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx; }
.quick-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.quick-icon {
  width: 96rpx; height: 96rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
}
.quick-label { font-size: 22rpx; color: #64748B; }
