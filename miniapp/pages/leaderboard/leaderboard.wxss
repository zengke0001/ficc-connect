/* pages/leaderboard/leaderboard.wxss */
.lb-page { background: var(--bg-secondary); min-height: 100vh; }

.type-bar {
  display: flex; background: white;
  padding: 20rpx 40rpx; gap: 16rpx;
}
.type-btn {
  flex: 1; text-align: center;
  padding: 16rpx; font-size: 26rpx; color: var(--text-muted);
  border-radius: 100rpx; transition: all 0.2s ease;
  background: var(--bg-secondary);
}
.type-btn:active {
  background: var(--border);
  transform: scale(0.98);
}
.type-btn.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.35);
  transform: scale(1.02);
}

/* Podium */
.podium {
  background: linear-gradient(160deg, var(--primary-dark), var(--primary-light));
  padding: 40rpx 40rpx 60rpx;
  display: flex; align-items: flex-end; justify-content: center; gap: 16rpx;
}
.podium-item { display: flex; flex-direction: column; align-items: center; }
.crown { font-size: 40rpx; margin-bottom: 8rpx; }
.podium-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.first-avatar { width: 116rpx; height: 116rpx; border: 5rpx solid var(--accent); }
.podium-name { font-size: 22rpx; color: white; margin: 10rpx 0 4rpx; max-width: 120rpx; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.podium-pts { font-size: 20rpx; color: rgba(255,255,255,0.8); margin-bottom: 8rpx; }
.podium-stand {
  font-size: 36rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx 16rpx 0 0;
}
.first-stand { background: rgba(255,255,255,0.25); padding-top: 24rpx; padding-bottom: 24rpx; }
.second-stand { background: rgba(255,255,255,0.15); }
.third-stand { background: rgba(255,255,255,0.1); }

/* My rank */
.my-rank-bar {
  display: flex; align-items: center; gap: 16rpx;
  background: var(--border-light); padding: 24rpx 32rpx;
  border-left: 6rpx solid var(--accent);
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
}
.my-rank-text { font-size: 24rpx; color: #92400E; }
.my-rank-val { font-size: 36rpx; font-weight: 800; color: var(--accent); }
.my-rank-pts { font-size: 24rpx; color: #92400E; flex: 1; }
.my-rank-hint { font-size: 22rpx; color: #92400E; }

/* Rank list */
.rank-list { margin: 20rpx 24rpx 40rpx; }
.rank-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.rank-row.top-row { background: rgba(255,184,0,0.06); border-radius: 12rpx; padding: 20rpx 12rpx; margin: 0 -12rpx; }
.rank-row.is-me { background: var(--border-light); border-radius: 12rpx; padding: 20rpx 12rpx; margin: 0 -12rpx; }
.rank-num { width: 52rpx; text-align: center; font-size: 28rpx; font-weight: 700; color: var(--text-muted); flex-shrink: 0; }
.rank-info { flex: 1; min-width: 0; }
.rank-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.rank-meta { font-size: 22rpx; color: var(--text-muted); margin-top: 4rpx; }
.team-text { font-weight: 500; }
.me-tag { background: var(--primary); color: white; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 100rpx; margin-left: 8rpx; }
.rank-score { text-align: right; }
.score-pts { font-size: 36rpx; font-weight: 800; color: var(--text-primary); }
.score-label { font-size: 20rpx; color: var(--text-muted); }
