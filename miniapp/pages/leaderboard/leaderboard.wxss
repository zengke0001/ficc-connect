/* pages/leaderboard/leaderboard.wxss */
.lb-page { background: var(--bg-secondary); min-height: 100vh; }

.type-bar {
  display: flex; background: white;
  padding: 20rpx 40rpx; gap: 16rpx;
}
.type-btn {
  flex: 1; text-align: center;
  padding: 16rpx; font-size: 26rpx; color: #94A3B8;
  border-radius: 100rpx; transition: all 0.2s;
}
.type-btn.active { background: #EFF6FF; color: #2563EB; font-weight: 700; }

/* Podium */
.podium {
  background: linear-gradient(160deg, #1D4ED8, #3B82F6);
  padding: 40rpx 40rpx 60rpx;
  display: flex; align-items: flex-end; justify-content: center; gap: 16rpx;
}
.podium-item { display: flex; flex-direction: column; align-items: center; }
.crown { font-size: 40rpx; margin-bottom: 8rpx; }
.podium-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.first-avatar { width: 116rpx; height: 116rpx; border: 5rpx solid #FBBF24; }
.podium-name { font-size: 22rpx; color: white; margin: 10rpx 0 4rpx; max-width: 120rpx; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.podium-pts { font-size: 20rpx; color: rgba(255,255,255,0.8); margin-bottom: 8rpx; }
.podium-stand {
  font-size: 36rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx 16rpx 0 0;
}
.first-stand { background: rgba(255,255,255,0.25); padding-top: 24rpx; padding-bottom: 24rpx; }
.second-stand { background: rgba(255,255,255,0.15); }
.third-stand { background: rgba(255,255,255,0.1); }

/* My rank */
.my-rank-bar {
  display: flex; align-items: center; gap: 16rpx;
  background: #FFF7ED; padding: 24rpx 32rpx;
  border-left: 6rpx solid #F59E0B;
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
}
.my-rank-text { font-size: 24rpx; color: #92400E; }
.my-rank-val { font-size: 36rpx; font-weight: 800; color: #F59E0B; }
.my-rank-pts { font-size: 24rpx; color: #92400E; flex: 1; }
.my-rank-hint { font-size: 22rpx; color: #92400E; }

/* Rank list */
.rank-list { margin: 20rpx 24rpx 40rpx; }
.rank-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}
.rank-row.top-row { background: rgba(245,158,11,0.04); border-radius: 12rpx; padding: 20rpx 12rpx; margin: 0 -12rpx; }
.rank-row.is-me { background: #EFF6FF; border-radius: 12rpx; padding: 20rpx 12rpx; margin: 0 -12rpx; }
.rank-num { width: 52rpx; text-align: center; font-size: 28rpx; font-weight: 700; color: #94A3B8; flex-shrink: 0; }
.rank-info { flex: 1; min-width: 0; }
.rank-name { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.rank-meta { font-size: 22rpx; color: #94A3B8; margin-top: 4rpx; }
.team-text { font-weight: 500; }
.me-tag { background: #2563EB; color: white; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 100rpx; margin-left: 8rpx; }
.rank-score { text-align: right; }
.score-pts { font-size: 36rpx; font-weight: 800; color: #1E293B; }
.score-label { font-size: 20rpx; color: #94A3B8; }
