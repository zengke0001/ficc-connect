<!-- pages/create-activity/create-activity.wxml -->
<scroll-view class="page-scroll" scroll-y>
  <view class="form-page">

    <!-- Cover Picker -->
    <view class="cover-section" bindtap="chooseCover">
      <image wx:if="{{coverPath}}" src="{{coverPath}}" mode="aspectFill" class="cover-preview"/>
      <view wx:else class="cover-placeholder">
        <text class="cover-icon">🖼️</text>
        <text class="cover-text">Tap to add cover image</text>
      </view>
    </view>

    <!-- Title -->
    <view class="form-section card card-body">
      <view class="form-label">Activity Title <text class="required">*</text></view>
      <input class="form-input" placeholder="e.g., 30-Day Early Rise Challenge" maxlength="50"
             data-field="title" bindinput="onInput" value="{{form.title}}"/>
    </view>

    <!-- Description -->
    <view class="form-section card card-body">
      <view class="form-label">Description <text class="required">*</text></view>
      <textarea class="form-textarea" placeholder="Rules and goals..." maxlength="500"
                auto-height data-field="description"
                bindinput="onInput" value="{{form.description}}"/>
    </view>

    <!-- Dates -->
    <view class="form-section card card-body">
      <view class="form-label">Duration <text class="required">*</text></view>
      <view class="date-row">
        <view class="date-field">
          <view class="date-label">Start Date</view>
          <picker mode="date" value="{{form.start_date}}" start="{{minDate}}"
                  data-field="start_date" bindchange="onInput">
            <view class="date-value">{{form.start_date || 'Select'}}</view>
          </picker>
        </view>
        <view class="date-separator">—</view>
        <view class="date-field">
          <view class="date-label">End Date</view>
          <picker mode="date" value="{{form.end_date}}" start="{{form.start_date || minDate}}"
                  data-field="end_date" bindchange="onInput">
            <view class="date-value">{{form.end_date || 'Select'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <!-- Points -->
    <view class="form-section card card-body">
      <view class="form-label">Points Settings</view>
      <view class="points-row">
        <view class="points-item">
          <view class="points-label">Per check-in</view>
          <view class="points-input-wrap">
            <input class="points-input" type="number" value="{{form.points_per_checkin}}"
                   data-field="points_per_checkin" bindinput="onInput"/>
            <text class="points-unit">pts</text>
          </view>
        </view>
        <view class="points-item">
          <view class="points-label">With photo</view>
          <view class="points-input-wrap">
            <input class="points-input" type="number" value="{{form.points_per_photo}}"
                   data-field="points_per_photo" bindinput="onInput"/>
            <text class="points-unit">pts</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Submit -->
    <view class="submit-area safe-bottom">
      <button class="btn btn-primary btn-block"
              loading="{{submitting}}" bindtap="submit">
        🚀 Create Activity
      </button>
    </view>

  </view>
</scroll-view>
