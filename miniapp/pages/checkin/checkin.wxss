/* pages/checkin/checkin.wxss */
.checkin-page { background: var(--bg-secondary); min-height: 100vh; }

.act-header { position: relative; height: 300rpx; }
.act-cover-img { width: 100%; height: 100%; }
.act-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 30rpx 32rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}
.act-name { font-size: 34rpx; font-weight: 700; color: white; }
.act-date { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

.section-card { margin: 24rpx 24rpx 0; }
.card-label { font-size: 26rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 20rpx; }

.photo-picker {
  height: 280rpx;
  border: 3rpx dashed var(--border);
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-secondary);
}
.picker-inner { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.picker-icon { font-size: 64rpx; }
.picker-text { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.picker-hint { font-size: 22rpx; color: var(--text-muted); }

.photo-preview { position: relative; height: 360rpx; border-radius: 20rpx; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.remove-photo {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 56rpx; height: 56rpx;
  background: rgba(0,0,0,0.5); color: white;
  border-radius: 50%; font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}
.input-placeholder { color: var(--text-muted); }
.char-count { text-align: right; font-size: 22rpx; color: var(--text-muted); margin-top: 12rpx; }

.submit-area { padding: 40rpx 24rpx 32rpx; }

/* Success overlay */
.success-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4px);
}
.success-card {
  background: white;
  border-radius: 40rpx;
  padding: 60rpx 48rpx;
  margin: 0 48rpx;
  text-align: center;
}
.success-emoji { font-size: 100rpx; margin-bottom: 20rpx; }
.success-title { font-size: 44rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 40rpx; }

.success-stats { display: flex; justify-content: center; align-items: center; gap: 40rpx; margin-bottom: 32rpx; }
.stat-item { text-align: center; }
.stat-value { font-size: 48rpx; font-weight: 800; }
.stat-label { font-size: 24rpx; color: var(--text-muted); margin-top: 8rpx; }
.stat-divider { width: 2rpx; height: 80rpx; background: var(--border); }
.gradient-orange-text { color: var(--accent); }
.gradient-fire-text { color: var(--danger); }

.streak-bonus {
  background: #FFF8EB;
  color: var(--accent);
  border-radius: 100rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.new-achievements {
  background: var(--border-light);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  text-align: left;
}
.achievements-title { font-size: 26rpx; font-weight: 700; color: var(--primary); margin-bottom: 16rpx; }
.achievement-item {
  display: flex; justify-content: space-between;
  font-size: 26rpx; color: var(--text-primary); padding: 8rpx 0;
}
.ach-points { color: var(--primary); font-weight: 600; }

.success-btn { margin-top: 8rpx; }
