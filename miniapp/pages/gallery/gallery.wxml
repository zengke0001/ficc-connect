<!-- pages/gallery/gallery.wxml -->
<view class="page-container">

  <!-- Header -->
  <view class="page-header">
    <text class="page-title">我的活动相册</text>
    <text class="page-subtitle">点击查看活动照片墙</text>
  </view>

  <!-- Loading -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <!-- Activity list -->
  <view class="activity-list" wx:elif="{{activities.length > 0}}">
    <view 
      wx:for="{{activities}}" 
      wx:key="id" 
      class="activity-card"
      bindtap="goToActivityGallery" 
      data-id="{{item.id}}">
      <image 
        class="card-cover" 
        src="{{item.cover_image_url || '/images/default-cover.png'}}" 
        mode="aspectFill"/>
      <view class="card-content">
        <view class="card-title">{{item.title}}</view>
        <view class="card-meta">
          <text class="meta-item">{{item.participant_count || 0}}人参与</text>
          <text class="meta-divider">·</text>
          <text class="meta-item">{{item.status === 'active' ? '进行中' : item.status === 'completed' ? '已结束' : '已归档'}}</text>
        </view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>

  <!-- Empty state -->
  <view class="empty-container" wx:else>
    <text class="empty-icon">📸</text>
    <text class="empty-title">暂无参与的活动</text>
    <text class="empty-desc">参加活动后，这里会显示你的活动相册</text>
  </view>

</view>
