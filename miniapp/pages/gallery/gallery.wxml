<!-- pages/gallery/gallery.wxml -->
<scroll-view class="page-scroll" scroll-y>

  <!-- Activity gallery -->
  <block wx:if="{{isActivityGallery}}">

    <!-- Winners podium (if activity ended) -->
    <view class="winners-section" wx:if="{{winners.length > 0}}">
      <view class="winners-header">
        <text class="winners-title">🏆 活动冠军</text>
      </view>
      <view class="winners-row">
        <view wx:for="{{winners}}" wx:key="id" class="winner-card">
          <view class="winner-rank">{{index === 0 ? '🥇' : index === 1 ? '🥈' : '🥉'}}</view>
          <image class="winner-avatar" src="{{item.avatar_url}}" mode="aspectFill"/>
          <view class="winner-name">{{item.nickname}}</view>
          <view class="winner-pts">{{item.total_points}}分</view>
          <view class="winner-streak" wx:if="{{item.max_streak > 0}}">最长{{item.max_streak}}天连击</view>
        </view>
      </view>
    </view>

    <!-- Stats bar -->
    <view class="stats-bar" wx:if="{{stats}}">
      <view class="stat-chip">
        <text class="s-val">{{stats.total_participants || 0}}</text>
        <text class="s-key">参与者</text>
      </view>
      <view class="stat-chip">
        <text class="s-val">{{stats.total_checkins || 0}}</text>
        <text class="s-key">总打卡</text>
      </view>
      <view class="stat-chip">
        <text class="s-val">{{stats.total_photos || 0}}</text>
        <text class="s-key">照片</text>
      </view>
    </view>

    <!-- Photo masonry grid -->
    <view class="section-title-pad">📸 活动照片墙</view>
    <view class="photo-masonry" wx:if="{{photos.length > 0}}">
      <view wx:for="{{photos}}" wx:key="id" class="photo-cell fade-in">
        <image src="{{item.thumbnail_url || item.url}}" mode="aspectFill"
               class="cell-img"
               data-url="{{item.url}}"
               bindtap="previewPhoto"/>
        <view class="cell-overlay">
          <view class="cell-user">
            <image class="cell-avatar" src="{{item.avatar_url}}" mode="aspectFill"/>
            <text class="cell-name">{{item.nickname}}</text>
          </view>
          <view class="cell-like" catchtap="likePhoto"
                data-photo-id="{{item.id}}"
                data-is-liked="{{item.is_liked}}">
            <text class="like-heart">{{item.is_liked ? '❤️' : '🤍'}}</text>
            <text class="like-count">{{item.likes_count}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{!loading}}">
      <text class="icon">📷</text>
      <text class="text">暂无打卡照片</text>
    </view>

  </block>

  <!-- My activities gallery list -->
  <block wx:else>
    <view class="gallery-list">
      <view wx:for="{{activities}}" wx:key="id" class="gallery-activity-card card"
            bindtap="goToActivityGallery" data-id="{{item.id}}">
        <image class="gallery-cover" src="{{item.cover_image_url || '/images/default-cover.png'}}" mode="aspectFill"/>
        <view class="gallery-info">
          <view class="gallery-title">{{item.title}}</view>
          <view class="gallery-meta">{{item.participant_count}}人参与</view>
        </view>
      </view>
    </view>
  </block>

  <view style="height: 40rpx;"></view>
</scroll-view>
