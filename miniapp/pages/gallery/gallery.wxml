<!-- pages/gallery/gallery.wxml -->
<view class="page-container">

  <!-- Header -->
  <view class="page-header">
    <text class="page-title">My Activity Gallery</text>
    <text class="page-subtitle">Tap to view photo collections</text>
  </view>

  <!-- Loading -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <!-- Activity list -->
  <view class="activity-list" wx:elif="{{activities.length > 0}}">
    <view 
      wx:for="{{activities}}" 
      wx:key="id" 
      class="activity-card"
      bindtap="goToActivityGallery" 
      data-id="{{item.id}}">
      <image 
        class="card-cover" 
        src="{{item.cover_image_url || '/images/default-cover.jpg'}}" 
        mode="aspectFill"/>
      <view class="card-content">
        <view class="card-title">{{item.title}}</view>
        <view class="card-meta">
          <text class="meta-item">{{item.participant_count || 0}} joined</text>
          <text class="meta-divider">·</text>
          <text class="meta-item">{{item.status === 'active' ? 'Active' : item.status === 'completed' ? 'Ended' : 'Archived'}}</text>
        </view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>

  <!-- Empty state -->
  <view class="empty-container" wx:else>
    <text class="empty-icon">📸</text>
    <text class="empty-title">No activities yet</text>
    <text class="empty-desc">Join activities to see your photo galleries here</text>
  </view>

</view>
