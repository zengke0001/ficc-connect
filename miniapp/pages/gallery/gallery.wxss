/* pages/gallery/gallery.wxss */

.page-container {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Header */
.page-header {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  padding: 40rpx 32rpx;
}
.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
}
.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* Loading skeleton */
.loading-container {
  padding: 20rpx;
}
.loading-item {
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
@keyframes loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Activity list */
.activity-list {
  padding: 20rpx;
}

.activity-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
}

.card-cover {
  width: 180rpx;
  height: 120rpx;
  flex-shrink: 0;
  background: var(--border);
}

.card-content {
  flex: 1;
  padding: 20rpx 24rpx;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-meta {
  font-size: 24rpx;
  color: var(--text-muted);
}

.meta-item {
  display: inline;
}

.meta-divider {
  margin: 0 8rpx;
  color: var(--border);
}

.card-arrow {
  font-size: 40rpx;
  color: var(--text-muted);
  padding-right: 24rpx;
}

/* Empty state */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
}
