/* pages/gallery/gallery.wxss */
.page-scroll { 
  background: #F8FAFC; 
  min-height: 100vh; 
}

/* Winners */
.winners-section { 
  background: linear-gradient(160deg, #2563EB, #1D4ED8); 
  padding: 40rpx 32rpx; 
}
.winners-header { text-align: center; margin-bottom: 32rpx; }
.winners-title { font-size: 36rpx; font-weight: 800; color: white; }
.winners-row { 
  display: flex; 
  justify-content: center; 
  flex-wrap: wrap;
  gap: 20rpx; 
}
.winner-card { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}
.winner-rank { font-size: 40rpx; margin-bottom: 8rpx; }
.winner-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.6); }
.winner-name { font-size: 24rpx; color: white; margin-top: 10rpx; text-align: center; font-weight: 600; }
.winner-pts { font-size: 22rpx; color: rgba(255,255,255,0.9); }
.winner-streak { font-size: 18rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }

/* Stats */
.stats-bar {
  display: flex; 
  justify-content: space-around;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  padding: 28rpx 40rpx;
  margin: 0 20rpx;
  border-radius: 16rpx;
}
.stat-chip { text-align: center; }
.s-val { display: block; font-size: 32rpx; font-weight: 700; color: #2563EB; }
.s-key { display: block; font-size: 22rpx; color: #64748B; margin-top: 6rpx; }

.section-title-pad {
  font-size: 28rpx; 
  font-weight: 600; 
  color: #1E293B;
  padding: 32rpx 24rpx 16rpx;
}

/* Photo grid - Android compatible */
.photo-masonry {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  padding: 0 4rpx;
}
.photo-cell { 
  position: relative; 
  width: 33.33%;
  height: 0;
  padding-bottom: 33.33%; /* aspect-ratio fallback for Android */
  overflow: hidden; 
}
.cell-img { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
  transition: transform 0.2s; 
}
.cell-img:active { transform: scale(1.05); }
.cell-overlay {
  position: absolute; 
  bottom: 0; 
  left: 0; 
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 20rpx 10rpx 10rpx;
  display: flex; 
  justify-content: space-between; 
  align-items: flex-end;
}
.cell-user { display: flex; align-items: center; gap: 6rpx; overflow: hidden; }
.cell-avatar { width: 32rpx; height: 32rpx; border-radius: 50%; flex-shrink: 0; }
.cell-name { 
  font-size: 18rpx; 
  color: white; 
  white-space: nowrap; 
  overflow: hidden; 
  text-overflow: ellipsis; 
  max-width: 120rpx; 
}
.cell-like { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.like-heart { font-size: 24rpx; }
.like-count { font-size: 18rpx; color: white; }

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #94A3B8;
}
.empty-state .icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-state .text { font-size: 28rpx; }

/* My gallery list */
.gallery-list { 
  padding: 20rpx; 
  background: #F8FAFC; 
}
.gallery-activity-card { 
  display: flex; 
  margin-bottom: 20rpx; 
  overflow: hidden; 
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.gallery-cover { 
  width: 200rpx; 
  height: 140rpx; 
  flex-shrink: 0; 
  background: #E2E8F0;
}
.gallery-info { 
  padding: 24rpx; 
  flex: 1; 
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.gallery-title { 
  font-size: 30rpx; 
  font-weight: 600; 
  color: #1E293B; 
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.gallery-meta { 
  font-size: 24rpx; 
  color: #94A3B8; 
  margin-top: 12rpx; 
}
