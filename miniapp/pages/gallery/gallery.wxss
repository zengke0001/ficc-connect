/* pages/gallery/gallery.wxss */
.page-scroll { background: #0F172A; min-height: 100vh; }

/* Winners */
.winners-section { background: linear-gradient(160deg, #1D4ED8, #7C3AED); padding: 40rpx 32rpx; }
.winners-header { text-align: center; margin-bottom: 32rpx; }
.winners-title { font-size: 36rpx; font-weight: 800; color: white; }
.winners-row { display: flex; justify-content: center; gap: 20rpx; }
.winner-card { display: flex; flex-direction: column; align-items: center; flex: 1; max-width: 200rpx; }
.winner-rank { font-size: 40rpx; margin-bottom: 8rpx; }
.winner-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.6); }
.winner-name { font-size: 24rpx; color: white; margin-top: 10rpx; text-align: center; font-weight: 600; }
.winner-pts { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.winner-streak { font-size: 18rpx; color: rgba(255,255,255,0.6); margin-top: 4rpx; }

/* Stats */
.stats-bar {
  display: flex; justify-content: space-around;
  background: #1E293B; padding: 28rpx 40rpx;
}
.stat-chip { text-align: center; }
.s-val { display: block; font-size: 36rpx; font-weight: 800; color: white; }
.s-key { display: block; font-size: 22rpx; color: #64748B; margin-top: 4rpx; }

.section-title-pad {
  font-size: 28rpx; font-weight: 600; color: #94A3B8;
  padding: 24rpx 24rpx 16rpx;
}

/* Photo grid */
.photo-masonry {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  padding: 0 4rpx;
}
.photo-cell { position: relative; aspect-ratio: 1; overflow: hidden; }
.cell-img { width: 100%; height: 100%; transition: transform 0.2s; }
.cell-img:active { transform: scale(1.05); }
.cell-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
  padding: 20rpx 10rpx 10rpx;
  display: flex; justify-content: space-between; align-items: flex-end;
}
.cell-user { display: flex; align-items: center; gap: 6rpx; overflow: hidden; }
.cell-avatar { width: 32rpx; height: 32rpx; border-radius: 50%; flex-shrink: 0; }
.cell-name { font-size: 18rpx; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120rpx; }
.cell-like { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.like-heart { font-size: 24rpx; }
.like-count { font-size: 18rpx; color: white; }

/* My gallery list */
.gallery-list { padding: 20rpx; background: var(--bg-secondary); }
.gallery-activity-card { display: flex; margin-bottom: 20rpx; overflow: hidden; }
.gallery-cover { width: 160rpx; height: 120rpx; flex-shrink: 0; }
.gallery-info { padding: 24rpx; flex: 1; }
.gallery-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.gallery-meta { font-size: 24rpx; color: #94A3B8; margin-top: 8rpx; }
