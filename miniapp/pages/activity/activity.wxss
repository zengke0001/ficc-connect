/* pages/activity/activity.wxss */
.container { background: var(--bg-secondary); min-height: 100vh; position: relative; }

.tabs {
  position: relative;
  display: flex;
  background: white;
  padding: 0 40rpx;
  border-bottom: 2rpx solid var(--border);
}
.tab {
  flex: 1; text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx; color: var(--text-muted);
  font-weight: 500; position: relative; z-index: 1;
  transition: all 0.2s ease;
}
.tab:active { opacity: 0.7; }
.tab.active {
  color: var(--primary);
  font-weight: 700;
  transform: scale(1.02);
}
.tab-indicator {
  position: absolute; bottom: 0; left: 0;
  width: 50%; height: 4rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 4rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 -2rpx 8rpx rgba(255, 107, 53, 0.3);
}

.activity-list { height: calc(100vh - 180rpx); }

.activity-card { margin: 24rpx 24rpx 0; overflow: hidden; }
.card-cover { width: 100%; height: 240rpx; display: block; background: var(--bg-tertiary); }
.card-content { padding: 28rpx; }
.card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; margin-bottom: 12rpx; }
.card-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); flex: 1; }
.days-left { flex-shrink: 0; }
.card-desc {
  font-size: 26rpx; color: var(--text-secondary); line-height: 1.5;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden;
  margin-bottom: 20rpx;
}
.card-footer { display: flex; align-items: center; gap: 12rpx; }
.creator-avatar { flex-shrink: 0; }
.creator-name { font-size: 24rpx; color: var(--text-secondary); }
.spacer { flex: 1; }
.participant-count { font-size: 24rpx; color: var(--text-muted); }

.skeleton-activity {
  height: 400rpx; border-radius: 24rpx; margin: 24rpx 24rpx 0;
  background: linear-gradient(90deg, var(--bg-tertiary) 25%, var(--border) 50%, var(--bg-tertiary) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.bottom-hint { text-align: center; padding: 32rpx; font-size: 24rpx; color: var(--text-muted); }

/* FAB */
.fab {
  position: fixed; right: 48rpx; bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx; height: 100rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.45);
  z-index: 10;
}
.fab-icon { font-size: 48rpx; color: white; line-height: 1; font-weight: 300; }
