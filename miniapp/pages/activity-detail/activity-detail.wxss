/* pages/activity-detail/activity-detail.wxss */
.cover-wrap { position: relative; height: 400rpx; }
.cover-img { width: 100%; height: 100%; }
.cover-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 40rpx 32rpx 28rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
}
.cover-title { font-size: 40rpx; font-weight: 800; color: white; margin-bottom: 12rpx; }

/* Date display */
.cover-date {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.date-period {
  font-size: 26rpx;
  color: rgba(255,255,255,0.95);
}
.date-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 600;
}
.date-status.active {
  background: rgba(0, 201, 167, 0.9);
  color: white;
}
.date-status.ended {
  background: rgba(148, 163, 184, 0.9);
  color: white;
}
.date-status.upcoming {
  background: rgba(255, 184, 0, 0.9);
  color: white;
}

.cover-meta { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-bottom: 12rpx; }

/* Progress bar */
.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.progress-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--success), var(--accent));
  border-radius: 8rpx;
  transition: width 0.3s ease;
}
.progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  min-width: 60rpx;
  text-align: right;
}

.cover-status { align-self: flex-start; }

.section { margin: 20rpx 24rpx 0; }
.section-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.see-more-link { font-size: 26rpx; color: var(--primary); }

/* My progress */
.my-progress { margin: 20rpx 24rpx 0; }
.progress-title { font-size: 26rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 24rpx; }
.progress-stats { display: flex; justify-content: space-around; }
.p-stat { text-align: center; }
.p-val { font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.p-label { font-size: 22rpx; color: var(--text-muted); margin-top: 6rpx; }
.gradient-orange-text { color: var(--accent); }
.gradient-purple-text { color: var(--highlight); }

/* Description */
.desc-text { font-size: 28rpx; color: #475569; line-height: 1.7; margin-bottom: 20rpx; }
.rule-row { display: flex; gap: 20rpx; flex-wrap: wrap; }
.rule-item {
  background: #E6FFF9; color: var(--success);
  font-size: 22rpx; padding: 8rpx 18rpx;
  border-radius: 100rpx; font-weight: 500;
}

/* Leaderboard */
.lb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.lb-tabs { display: flex; background: var(--bg-tertiary); border-radius: 100rpx; padding: 6rpx; }
.lb-tab {
  padding: 8rpx 20rpx; font-size: 24rpx; color: var(--text-muted);
  border-radius: 100rpx; transition: all 0.2s ease;
}
.lb-tab:active {
  background: var(--border);
  transform: scale(0.95);
}
.lb-tab.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.35);
  transform: scale(1.05);
}

.rank-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.rank-row:last-of-type { border-bottom: none; }
.rank-row.top-three { background: linear-gradient(90deg, rgba(255,184,0,0.06), transparent); border-radius: 16rpx; padding: 20rpx 12rpx; margin: 0 -12rpx; }
.rank-medal { width: 48rpx; text-align: center; font-size: 32rpx; flex-shrink: 0; }
.rank-info { flex: 1; min-width: 0; }
.rank-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.rank-team { font-size: 22rpx; margin-top: 4rpx; }
.rank-right { text-align: right; }
.rank-points { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.rank-streak { font-size: 22rpx; color: var(--danger); margin-top: 4rpx; }
.see-more { text-align: center; color: var(--primary); font-size: 26rpx; padding-top: 20rpx; }

/* Photos grid */
.photo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8rpx; }
.photo-item { position: relative; aspect-ratio: 1; }
.photo-img { width: 100%; height: 100%; border-radius: 12rpx; }
.photo-like {
  position: absolute; bottom: 8rpx; right: 8rpx;
  display: flex; align-items: center; gap: 4rpx;
  background: rgba(0,0,0,0.45); border-radius: 100rpx;
  padding: 4rpx 12rpx;
}
.like-count { font-size: 20rpx; color: white; }

/* Action bar */
.action-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: white;
  padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}
.checkin-action-btn {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white; font-size: 34rpx; font-weight: 700;
  text-align: center; padding: 28rpx;
  border-radius: 60rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
}

.skeleton-header { height: 400rpx; background: var(--bg-tertiary); }
