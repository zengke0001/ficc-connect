<!-- pages/activity-detail/activity-detail.wxml -->
<scroll-view class="page-scroll" scroll-y>
  <view wx:if="{{loading}}" class="loading-state">
    <view class="skeleton-header"></view>
  </view>

  <block wx:elif="{{activity}}">

    <!-- Cover image -->
    <view class="cover-wrap">
      <image class="cover-img" src="{{activity.cover_image_url || '/images/default-cover.jpg'}}" mode="aspectFill"/>
      <view class="cover-overlay">
        <view class="cover-title">{{activity.title}}</view>
        <view class="cover-date">
          <text class="date-period">📅 {{dateInfo.period}}</text>
          <text class="date-status {{dateInfo.status}}">{{dateInfo.text}}</text>
        </view>
        <view class="cover-meta">
          <text>👥 {{activity.participant_count}} joined</text>
          <text wx:if="{{dateInfo.status === 'active'}}"> · Day {{dateInfo.currentDay}}/{{dateInfo.totalDays}}</text>
        </view>
        <!-- Progress bar -->
        <view class="progress-bar-wrap" wx:if="{{dateInfo.status === 'active'}}">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{dateInfo.progress}}%"></view>
          </view>
          <text class="progress-text">{{dateInfo.progress}}%</text>
        </view>
        <view class="cover-status tag {{activity.status === 'active' ? 'tag-green' : 'tag-purple'}}">
          {{activity.status === 'active' ? 'Active' : 'Ended'}}
        </view>
      </view>
    </view>

    <!-- My progress (if joined) -->
    <view class="my-progress card card-body" wx:if="{{isJoined && userParticipant}}">
      <view class="progress-title">My Progress</view>
      <view class="progress-stats">
        <view class="p-stat">
          <view class="p-val">{{userParticipant.total_checkins}}</view>
          <view class="p-label">Check-ins</view>
        </view>
        <view class="p-stat">
          <view class="p-val gradient-orange-text">{{userParticipant.current_streak}}🔥</view>
          <view class="p-label">Current Streak</view>
        </view>
        <view class="p-stat">
          <view class="p-val gradient-purple-text">{{userParticipant.total_points}}</view>
          <view class="p-label">Total Points</view>
        </view>
      </view>
    </view>

    <!-- Description -->
    <view class="section card card-body">
      <view class="section-title">About</view>
      <view class="desc-text">{{activity.description}}</view>
      <view class="rule-row">
        <text class="rule-item">+{{activity.points_per_checkin}} pts per check-in</text>
        <text class="rule-item">+{{activity.points_per_photo}} pts with photo</text>
      </view>
    </view>

    <!-- Leaderboard -->
    <view class="section card card-body">
      <view class="lb-header">
        <view class="section-title">Leaderboard</view>
        <view class="lb-tabs">
          <view class="lb-tab {{leaderboardType === 'daily' ? 'active' : ''}}"
                bindtap="switchLeaderboard" data-type="daily">Today</view>
          <view class="lb-tab {{leaderboardType === 'weekly' ? 'active' : ''}}"
                bindtap="switchLeaderboard" data-type="weekly">Week</view>
          <view class="lb-tab {{leaderboardType === 'overall' ? 'active' : ''}}"
                bindtap="switchLeaderboard" data-type="overall">All</view>
        </view>
      </view>

      <view wx:for="{{leaderboard}}" wx:key="id" class="rank-row {{index < 3 ? 'top-three' : ''}}">
        <view class="rank-medal">{{item.medal}}</view>
        <image class="avatar avatar-sm" src="{{item.avatar_url}}" mode="aspectFill"/>
        <view class="rank-info">
          <view class="rank-name">{{item.nickname}}</view>
          <view class="rank-team tag-text" style="color: {{item.team_color}}">{{item.team_name}}</view>
        </view>
        <view class="rank-right">
          <view class="rank-points">{{item.points}} pts</view>
          <view class="rank-streak" wx:if="{{item.current_streak > 0}}">🔥{{item.current_streak}}</view>
        </view>
      </view>

      <view class="see-more" bindtap="goToLeaderboard">View Full Ranking ›</view>
    </view>

    <!-- Recent photos -->
    <view class="section card card-body" wx:if="{{recentPhotos.length > 0}}">
      <view class="section-header-row">
        <view class="section-title">Recent Photos</view>
        <view class="see-more-link" bindtap="goToGallery">View All ›</view>
      </view>
      <view class="photo-grid">
        <view wx:for="{{recentPhotos}}" wx:key="id" class="photo-item">
          <image src="{{item.thumbnail_url || item.url}}" mode="aspectFill" class="photo-img"/>
          <view class="photo-like" catchtap="likePhoto"
                data-photo-id="{{item.id}}"
                data-is-liked="{{item.is_liked}}">
            <text>{{item.is_liked ? '❤️' : '🤍'}}</text>
            <text class="like-count">{{item.likes_count}}</text>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 200rpx;"></view>

  </block>

  <!-- Bottom action bar -->
  <view class="action-bar safe-bottom" wx:if="{{activity}}">
    <view wx:if="{{!isJoined && activity.status === 'active'}}"
          class="btn btn-primary btn-block"
          bindtap="joinActivity">
      Join Activity 🚀
    </view>
    <view wx:elif="{{isJoined && activity.status === 'active'}}"
          class="checkin-action-btn"
          bindtap="goToCheckin">
      🔥 Check-in Now
    </view>
    <view wx:else class="btn btn-secondary btn-block" bindtap="goToGallery">
      View Gallery 📸
    </view>
  </view>

</scroll-view>
