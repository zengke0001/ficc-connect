<!-- pages/profile/profile.wxml -->
<scroll-view class="page-scroll" scroll-y>

  <!-- Header gradient -->
  <view class="profile-header gradient-blue">
    <view class="avatar-wrap" bindtap="updateAvatar">
      <image class="avatar avatar-xl" src="{{user.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="avatar-edit">📷</view>
    </view>
    <view class="user-name">{{user.nickname}}</view>
    <view class="user-team tag tag-white" wx:if="{{user.team_name}}">
      <view class="team-dot-sm" style="background: {{user.team_color}};"></view>
      {{user.team_name}}
    </view>
    <view class="user-points points-badge">⭐ {{user.total_points}} Points</view>
  </view>

  <!-- Stats row -->
  <view class="stats-row card">
    <view class="stat-block">
      <view class="sb-val">{{stats.activities_joined || 0}}</view>
      <view class="sb-label">Activities</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-block">
      <view class="sb-val">{{stats.total_checkins || 0}}</view>
      <view class="sb-label">Check-ins</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-block">
      <view class="sb-val streak-val">{{stats.max_streak || 0}}🔥</view>
      <view class="sb-label">Best Streak</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-block">
      <view class="sb-val ach-val">{{stats.achievements_earned || 0}}</view>
      <view class="sb-label">Achievements</view>
    </view>
  </view>

  <!-- Achievements -->
  <view class="section card card-body" wx:if="{{achievements.length > 0}}">
    <view class="section-title">My Achievements</view>
    <view class="achievement-grid">
      <view wx:for="{{achievements}}" wx:key="id" class="ach-item pop-in">
        <view class="ach-icon">{{item.icon_url || '🏅'}}</view>
        <view class="ach-name">{{item.name}}</view>
      </view>
    </view>
  </view>

  <!-- Settings list -->
  <view class="settings-section card">
    <view class="settings-item" bindtap="editNickname">
      <text class="settings-icon">✏️</text>
      <text class="settings-label">Edit Nickname</text>
      <text class="settings-value">{{user.nickname}}</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-divider"></view>
    <view class="settings-item" bindtap="goToArchived">
      <text class="settings-icon">📂</text>
      <text class="settings-label">Archived Activities</text>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-divider"></view>
    <view class="settings-item" bindtap="logout">
      <text class="settings-icon">🚪</text>
      <text class="settings-label settings-danger">Log Out</text>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <view style="height: 60rpx;"></view>
</scroll-view>

<!-- Edit Nickname Modal -->
<view class="modal-overlay" wx:if="{{showNicknameModal}}" bindtap="closeNicknameModal">
  <view class="modal-content" catchtap="">
    <view class="modal-header">
      <text class="modal-title">Edit Nickname</text>
      <view class="modal-close" bindtap="closeNicknameModal">✕</view>
    </view>
    <view class="modal-body">
      <input class="nickname-edit-input" 
             type="nickname"
             placeholder="Enter your nickname"
             value="{{editNickname}}"
             bindinput="onEditNicknameInput"
             focus="{{showNicknameModal}}"/>
      <view class="nickname-hint">Tap to use your WeChat nickname</view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="closeNicknameModal">Cancel</button>
      <button class="btn btn-primary" bindtap="saveNickname">Save</button>
    </view>
  </view>
</view>
