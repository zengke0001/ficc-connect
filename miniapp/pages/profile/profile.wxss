/* pages/profile/profile.wxss */
.profile-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
}
.avatar-wrap { position: relative; margin-bottom: 20rpx; }
.avatar-edit {
  position: absolute; bottom: 0; right: 0;
  width: 44rpx; height: 44rpx;
  background: white; border-radius: 50%;
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}
.user-name { font-size: 40rpx; font-weight: 800; color: white; margin-bottom: 12rpx; }
.tag-white { background: rgba(255,255,255,0.2); color: white; margin-bottom: 16rpx; }
.team-dot-sm { width: 16rpx; height: 16rpx; border-radius: 50%; }
.user-points { margin-top: 4rpx; }

/* Stats */
.stats-row {
  display: flex; margin: -28rpx 24rpx 0;
  position: relative; z-index: 1;
  border-radius: 24rpx; overflow: hidden;
  padding: 32rpx 0;
}
.stat-block { flex: 1; text-align: center; }
.sb-val { font-size: 40rpx; font-weight: 800; color: var(--text-primary); }
.sb-label { font-size: 22rpx; color: var(--text-muted); margin-top: 6rpx; }
.streak-val { color: var(--danger); }
.ach-val { color: var(--primary); }
.stat-divider { width: 1rpx; background: var(--border); }

/* Section */
.section { margin: 24rpx 24rpx 0; }

/* Achievements */
.achievement-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx;
}
.ach-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.ach-icon {
  width: 100rpx; height: 100rpx; border-radius: 24rpx;
  background: linear-gradient(135deg, var(--border-light), var(--bg-tertiary));
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.12);
}
.ach-name { font-size: 20rpx; color: var(--text-secondary); text-align: center; }

/* Settings */
.settings-section { margin: 24rpx 24rpx 0; overflow: hidden; }
.settings-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 36rpx 32rpx;
}
.settings-icon { font-size: 36rpx; flex-shrink: 0; }
.settings-label { flex: 1; font-size: 30rpx; color: var(--text-primary); }
.settings-value {
  font-size: 28rpx;
  color: var(--text-muted);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.settings-danger { color: var(--danger); }
.settings-arrow { font-size: 32rpx; color: var(--text-muted); }
.settings-divider { height: 1rpx; background: var(--border); margin: 0 24rpx; }

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-content {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.modal-close {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 8rpx;
}
.modal-body {
  padding: 32rpx;
}
.nickname-edit-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}
.nickname-edit-input:focus {
  border-color: var(--primary);
}
.nickname-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  text-align: center;
}
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
}
.modal-footer .btn {
  flex: 1;
}
