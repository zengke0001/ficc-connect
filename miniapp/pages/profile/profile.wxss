/* pages/profile/profile.wxss */
.profile-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
}
.avatar-wrap { position: relative; margin-bottom: 20rpx; }
.avatar-edit {
  position: absolute; bottom: 0; right: 0;
  width: 44rpx; height: 44rpx;
  background: white; border-radius: 50%;
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}
.user-name { font-size: 40rpx; font-weight: 800; color: white; margin-bottom: 12rpx; }
.tag-white { background: rgba(255,255,255,0.2); color: white; margin-bottom: 16rpx; }
.team-dot-sm { width: 16rpx; height: 16rpx; border-radius: 50%; }
.user-points { margin-top: 4rpx; }

/* Stats */
.stats-row {
  display: flex; margin: -28rpx 24rpx 0;
  position: relative; z-index: 1;
  border-radius: 24rpx; overflow: hidden;
  padding: 32rpx 0;
}
.stat-block { flex: 1; text-align: center; }
.sb-val { font-size: 40rpx; font-weight: 800; color: #1E293B; }
.sb-label { font-size: 22rpx; color: #94A3B8; margin-top: 6rpx; }
.streak-val { color: #EF4444; }
.ach-val { color: #7C3AED; }
.stat-divider { width: 1rpx; background: #F1F5F9; }

/* Section */
.section { margin: 24rpx 24rpx 0; }

/* Achievements */
.achievement-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx;
}
.ach-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.ach-icon {
  width: 100rpx; height: 100rpx; border-radius: 24rpx;
  background: linear-gradient(135deg, #F5F3FF, #EDE9FE);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(124,58,237,0.15);
}
.ach-name { font-size: 20rpx; color: #64748B; text-align: center; }

/* Settings */
.settings-section { margin: 24rpx 24rpx 0; overflow: hidden; }
.settings-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 36rpx 32rpx;
}
.settings-icon { font-size: 36rpx; flex-shrink: 0; }
.settings-label { flex: 1; font-size: 30rpx; color: #1E293B; }
.settings-danger { color: #EF4444; }
.settings-arrow { font-size: 32rpx; color: #CBD5E1; }
.settings-divider { height: 1rpx; background: #F1F5F9; margin: 0 24rpx; }
