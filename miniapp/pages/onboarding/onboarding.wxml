<!-- pages/onboarding/onboarding.wxml -->
<view class="container onboarding">

  <!-- Welcome Step -->
  <block wx:if="{{step === 0}}">
    <view class="hero gradient-blue">
      <view class="hero-emoji">🏆</view>
      <view class="hero-title">FICC Connect</view>
      <view class="hero-subtitle">Check in together, grow together</view>
    </view>

    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">🔥</text>
        <view class="feature-text">
          <view class="feature-title">Daily Check-in</view>
          <view class="feature-desc">Stay consistent, build streaks, earn glory</view>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📸</text>
        <view class="feature-text">
          <view class="feature-title">Share Photos</view>
          <view class="feature-desc">Capture moments, get likes from colleagues</view>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🏅</text>
        <view class="feature-text">
          <view class="feature-title">Leaderboard</view>
          <view class="feature-desc">Compete with colleagues, win activity champions</view>
        </view>
      </view>
    </view>

    <view class="login-area safe-bottom">
      <button class="btn btn-primary btn-block btn-wechat"
              loading="{{loading}}"
              bindtap="handleLogin">
        <text>Login with WeChat</text>
      </button>
      <view class="tip">By logging in, you agree to our terms of service</view>
    </view>
  </block>

  <!-- Team Select Step -->
  <block wx:if="{{step === 1}}">
    <view class="team-header">
      <view class="team-title">Select Your Department</view>
      <view class="team-subtitle">For team challenges and rankings</view>
    </view>

    <view class="team-grid">
      <view wx:for="{{teams}}" wx:key="id"
            class="team-item {{selectedTeamId === item.id ? 'selected' : ''}}"
            style="border-color: {{selectedTeamId === item.id ? item.color : 'transparent'}};"
            bindtap="selectTeam"
            data-id="{{item.id}}">
        <view class="team-dot" style="background: {{item.color}};"></view>
        <view class="team-name">{{item.name}}</view>
        <view class="team-check" wx:if="{{selectedTeamId === item.id}}">✓</view>
      </view>
    </view>

    <view class="team-action safe-bottom">
      <button class="btn btn-primary btn-block"
              disabled="{{!selectedTeamId}}"
              bindtap="confirmTeam">
        Confirm & Start! 🚀
      </button>
    </view>
  </block>

</view>
