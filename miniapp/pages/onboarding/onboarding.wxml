<!-- pages/onboarding/onboarding.wxml -->
<view class="container onboarding">

  <!-- Login Step (step=0) -->
  <block wx:if="{{step === 0}}">
    <view class="hero gradient-blue">
      <view class="hero-emoji">🏆</view>
      <view class="hero-title">FICC Connect</view>
      <view class="hero-subtitle">Check in together, grow together</view>
    </view>

    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">🔥</text>
        <view class="feature-text">
          <view class="feature-title">Daily Check-in</view>
          <view class="feature-desc">Stay consistent, build streaks, earn glory</view>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📸</text>
        <view class="feature-text">
          <view class="feature-title">Share Photos</view>
          <view class="feature-desc">Capture moments, get likes from colleagues</view>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🏅</text>
        <view class="feature-text">
          <view class="feature-title">Leaderboard</view>
          <view class="feature-desc">Compete with colleagues, win activity champions</view>
        </view>
      </view>
    </view>

    <!-- Login Form -->
    <view class="auth-form">
      <view class="form-title">Sign In</view>

      <view class="form-group">
        <view class="form-label">Email</view>
        <view class="input-wrapper">
          <text class="input-icon">📧</text>
          <input class="form-input"
                 type="text"
                 placeholder="Enter your email"
                 bindinput="onLoginEmailInput"
                 value="{{loginEmail}}"/>
        </view>
      </view>

      <view class="form-actions safe-bottom">
        <button class="btn btn-primary btn-block"
                loading="{{loading}}"
                disabled="{{!loginEmail}}"
                bindtap="handleLogin">
          Sign In
        </button>
        <view class="form-switch">
          <text class="form-switch-text">Don't have an account? </text>
          <text class="form-switch-link" bindtap="goToRegister">Sign Up</text>
        </view>
      </view>
    </view>
  </block>

  <!-- Register Step (step=1) -->
  <block wx:if="{{step === 1}}">
    <view class="hero gradient-blue hero-compact">
      <view class="hero-emoji">🚀</view>
      <view class="hero-title">Create Account</view>
      <view class="hero-subtitle">Join FICC Connect with an invite code</view>
    </view>

    <view class="auth-form">
      <view class="form-title">Sign Up</view>

      <view class="form-group">
        <view class="form-label">Email</view>
        <view class="input-wrapper">
          <text class="input-icon">📧</text>
          <input class="form-input"
                 type="text"
                 placeholder="Enter your email"
                 bindinput="onEmailInput"
                 value="{{email}}"/>
        </view>
      </view>

      <view class="form-group">
        <view class="form-label">Nickname (Optional)</view>
        <view class="input-wrapper">
          <text class="input-icon">👤</text>
          <input class="form-input"
                 type="text"
                 placeholder="Choose a display name"
                 bindinput="onNicknameInput"
                 value="{{nickname}}"
                 maxlength="50"/>
        </view>
      </view>

      <view class="form-group">
        <view class="form-label">Invite Code</view>
        <view class="input-wrapper">
          <text class="input-icon">🔑</text>
          <input class="form-input invite-code-input"
                 type="text"
                 placeholder="Enter invite code"
                 bindinput="onInviteCodeInput"
                 value="{{inviteCode}}"/>
        </view>
        <view class="form-hint">Ask a member for the invite code</view>
      </view>

      <view class="form-actions safe-bottom">
        <button class="btn btn-primary btn-block"
                loading="{{loading}}"
                disabled="{{!email || !inviteCode}}"
                bindtap="handleRegister">
          Create Account
        </button>
        <view class="form-switch">
          <text class="form-switch-text">Already have an account? </text>
          <text class="form-switch-link" bindtap="goToLogin">Sign In</text>
        </view>
      </view>
    </view>
  </block>

  <!-- Team Select Step (step=2) -->
  <block wx:if="{{step === 2}}">
    <view class="team-header">
      <view class="team-title">Select Your Team</view>
      <view class="team-subtitle">For team challenges and rankings</view>
    </view>

    <view class="team-grid">
      <view wx:for="{{teams}}" wx:key="id"
            class="team-item {{selectedTeamId === item.id ? 'selected' : ''}}"
            style="border-color: {{selectedTeamId === item.id ? item.color : 'transparent'}};"
            bindtap="selectTeam"
            data-id="{{item.id}}">
        <view class="team-dot" style="background: {{item.color}};"></view>
        <view class="team-name">{{item.name}}</view>
        <view class="team-check" wx:if="{{selectedTeamId === item.id}}">✓</view>
      </view>
    </view>

    <view class="team-action safe-bottom">
      <button class="btn btn-primary btn-block"
              disabled="{{!selectedTeamId}}"
              bindtap="confirmTeam">
        Confirm & Start!
      </button>
      <view class="team-skip" bindtap="skipTeam">
        <text class="team-skip-text">Skip for now</text>
      </view>
    </view>
  </block>

</view>
