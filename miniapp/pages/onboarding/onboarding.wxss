/* pages/onboarding/onboarding.wxss */
.onboarding { background: #FFFFFF; min-height: 100vh; }

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx 80rpx;
  background: linear-gradient(160deg, #1D4ED8 0%, #2563EB 50%, #3B82F6 100%);
  border-radius: 0 0 60rpx 60rpx;
}
.hero-emoji { font-size: 120rpx; margin-bottom: 30rpx; }
.hero-title { font-size: 56rpx; font-weight: 800; color: white; letter-spacing: 4rpx; }
.hero-subtitle { font-size: 30rpx; color: rgba(255,255,255,0.8); margin-top: 16rpx; }

.features { padding: 60rpx 48rpx; }
.feature-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}
.feature-item:last-child { border-bottom: none; }
.feature-icon { font-size: 60rpx; }
.feature-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.feature-desc { font-size: 24rpx; color: #64748B; margin-top: 6rpx; }

.login-area { padding: 40rpx 48rpx; }
.btn-wechat { font-size: 32rpx; letter-spacing: 2rpx; }
.tip { text-align: center; font-size: 22rpx; color: #94A3B8; margin-top: 20rpx; }

/* Team Select */
.team-header { padding: 60rpx 48rpx 40rpx; text-align: center; }
.team-title { font-size: 44rpx; font-weight: 800; color: #1E293B; }
.team-subtitle { font-size: 26rpx; color: #64748B; margin-top: 12rpx; }

.team-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 40rpx;
}
.team-item {
  position: relative;
  background: #F8FAFC;
  border: 3rpx solid transparent;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.2s;
}
.team-item.selected { background: #EFF6FF; }
.team-dot { width: 20rpx; height: 20rpx; border-radius: 50%; flex-shrink: 0; }
.team-name { font-size: 28rpx; font-weight: 500; color: #1E293B; flex: 1; }
.team-check {
  position: absolute; top: 12rpx; right: 12rpx;
  width: 32rpx; height: 32rpx;
  background: #2563EB; color: white;
  border-radius: 50%; font-size: 18rpx;
  display: flex; align-items: center; justify-content: center;
}

.team-action { padding: 40rpx 48rpx; }
