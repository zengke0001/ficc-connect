/* pages/onboarding/onboarding.wxss */
.onboarding { background: #FFFFFF; min-height: 100vh; }

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx 80rpx;
  background: linear-gradient(160deg, #E85D2A 0%, #FF6B35 50%, #FF8F6B 100%);
  border-radius: 0 0 60rpx 60rpx;
}
.hero-compact {
  padding: 70rpx 60rpx 60rpx;
}
.hero-emoji { font-size: 120rpx; margin-bottom: 30rpx; }
.hero-title { font-size: 56rpx; font-weight: 800; color: white; letter-spacing: 4rpx; }
.hero-subtitle { font-size: 30rpx; color: rgba(255,255,255,0.8); margin-top: 16rpx; }

.features { padding: 60rpx 48rpx; }
.feature-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.feature-item:last-child { border-bottom: none; }
.feature-icon { font-size: 60rpx; }
.feature-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.feature-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }

/* Auth Form */
.auth-form {
  padding: 40rpx 48rpx;
  background: var(--bg-secondary);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: -20rpx;
}
.form-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 40rpx;
}
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}
.input-wrapper {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  transition: border-color 0.2s;
}
.input-wrapper:focus-within {
  border-color: var(--primary);
}
.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.form-input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
}
.invite-code-input {
  text-transform: uppercase;
  letter-spacing: 4rpx;
  font-family: monospace;
}
.form-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  padding-left: 4rpx;
}
.form-actions {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}
.form-switch {
  text-align: center;
  margin-top: 28rpx;
}
.form-switch-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.form-switch-link {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

.tip { text-align: center; font-size: 22rpx; color: var(--text-muted); margin-top: 20rpx; }

/* Team Select */
.team-header { padding: 60rpx 48rpx 40rpx; text-align: center; }
.team-title { font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.team-subtitle { font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; }

.team-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 40rpx;
}
.team-item {
  position: relative;
  background: var(--bg-secondary);
  border: 3rpx solid transparent;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.2s;
}
.team-item.selected { background: var(--bg-tertiary); }
.team-dot { width: 20rpx; height: 20rpx; border-radius: 50%; flex-shrink: 0; }
.team-name { font-size: 28rpx; font-weight: 500; color: var(--text-primary); flex: 1; }
.team-check {
  position: absolute; top: 12rpx; right: 12rpx;
  width: 32rpx; height: 32rpx;
  background: var(--primary); color: white;
  border-radius: 50%; font-size: 18rpx;
  display: flex; align-items: center; justify-content: center;
}

.team-action { padding: 40rpx 48rpx; }
.team-skip {
  text-align: center;
  margin-top: 24rpx;
}
.team-skip-text {
  font-size: 26rpx;
  color: var(--text-muted);
}
