# Database Configuration (SQLite)
DB_PATH=./data/ficc_connect.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# WeChat Mini-App Configuration
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# Storage Provider: 's3' | 'oss' | 'cos'
STORAGE_PROVIDER=cos

# Tencent COS Configuration (Recommended for WeChat)
COS_REGION=ap-guangzhou
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-name

# AWS S3 Configuration (Alternative)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your-bucket-name

# Alibaba OSS Configuration (Alternative)
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key
OSS_ACCESS_KEY_SECRET=your_secret
OSS_BUCKET=your-bucket-name

# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Rate Limiting
# Window size in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP (increase for higher concurrency)
RATE_LIMIT_MAX_REQUESTS=1000

# PWA Authentication
INVITE_CODE=your_invite_code_here
